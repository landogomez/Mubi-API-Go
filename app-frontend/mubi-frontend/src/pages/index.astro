---
import '../styles/global.css';

const res = await fetch('http://52.90.181.148:3000/api/movies');
const movies = await res.json();
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<title>Mubi Tribute | Director's Cut</title>
	</head>
	<body class="bg-zinc-950 text-stone-200 font-sans selection:bg-[#7f1d1d] selection:text-white antialiased">
		<main class="max-w-7xl mx-auto px-6 py-20">
			
			<header class="mb-24 flex flex-col items-center text-center">
				<h1 class="text-3xl md:text-5xl font-black uppercase tracking-[0.25em] text-stone-100 mb-6">
					Tops de Orlando
				</h1>
				<div class="h-[2px] w-16 bg-[#b33939] opacity-80"></div>
			</header>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
				{movies.map((movie) => (
					<div class="group cursor-pointer flex flex-col">
						
						<div class="relative overflow-hidden bg-zinc-900 aspect-[2/3] shadow-2xl border border-white/5">
							
							<img 
								src={movie.poster_url || "https://via.placeholder.com/400x600?text=No+Poster"} 
								alt={movie.title}
								class="w-full h-full object-cover grayscale sepia-[.20] contrast-125 opacity-75 group-hover:grayscale-0 group-hover:sepia-0 group-hover:contrast-100 group-hover:opacity-100 transition-all duration-[800ms] ease-out scale-105 group-hover:scale-100"
							/>
							
							<div class="absolute inset-0 bg-gradient-to-t from-zinc-950/90 via-transparent to-transparent opacity-80 group-hover:opacity-30 transition-opacity duration-[800ms]"></div>
						</div>
						
						<div class="mt-8 flex flex-col items-center text-center px-4">
							<h2 class="text-xl font-bold uppercase tracking-[0.15em] text-stone-100 leading-tight">
								{movie.title}
							</h2>
							
							<p class="mt-4 font-mono text-[0.65rem] uppercase tracking-[0.3em] text-[#b33939]">
								{movie.director} <span class="mx-3 text-zinc-700">|</span> {movie.year}
							</p>
						</div>

					</div>
				))}
			</div>
		</main>
	</body>
</html>